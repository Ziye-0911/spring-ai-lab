{
  "properties": [
    {
      "name": "spring.ai.lab.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用 Spring AI Lab.",
      "defaultValue": true
    },
    {
      "name": "spring.ai.lab.memory.type",
      "type": "java.lang.String",
      "description": "对话记忆类型: in-memory / redis.",
      "defaultValue": "in-memory"
    },
    {
      "name": "spring.ai.lab.memory.max-history",
      "type": "java.lang.Integer",
      "description": "最大保留历史消息数.",
      "defaultValue": 20
    },
    {
      "name": "spring.ai.lab.memory.ttl-minutes",
      "type": "java.lang.Integer",
      "description": "会话过期时间（分钟）.",
      "defaultValue": 30
    }
  ]
}
